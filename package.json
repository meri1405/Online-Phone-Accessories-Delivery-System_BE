{
  "name": "phone-accessories",
  "version": "1.0.0",
  "main": "src/server.js",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "imports": {
    "#configs/*": "./src/configs/*",
    "#constants/*": "./src/constants/*",
    "#controllers/*": "./src/controllers/*",
    "#middlewares/*": "./src/middlewares/*",
    "#models/*": "./src/models/*",
    "#providers/*": "./src/providers/*",
    "#repositories/*": "./src/repositories/*",
    "#routes/*": "./src/routes/*",
    "#services/*": "./src/services/*",
    "#sockets/*": "./src/sockets/*",
    "#utils/*": "./src/utils/*",
    "#validations/*": "./src/validations/*"
  },
  "scripts": {
    "build": "rimraf dist && copyfiles -u 1 \"src/**/*\" dist",
    "predev": "npm run build",
    "dev": "cross-env NODE_ENV=dev concurrently \"copyfiles -u 1 src/**/* dist -w\" \"nodemon -q dist/server.js\"",
    "prestart": "npm run build",
    "start": "cross-env NODE_ENV=dev node dist/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "async-exit-hook": "^2.0.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-basic-auth": "^1.2.1",
    "http-status-codes": "^2.3.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.0",
    "mongoose-paginate-v2": "^1.9.1",
    "nodemailer": "^7.0.12",
    "rimraf": "^6.1.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "nodemon": "^3.1.11"
  }
}
